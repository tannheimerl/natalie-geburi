# Das gemeinsame Passwort, mit dem man die Seite freischaltet.
# In Vercel unter Project Settings -> Environment Variables setzen.
SITE_PASSWORD=

# Geheimer Wert, der zum Signieren/Hashen des Auth-Cookies verwendet wird.
# Beliebige lange Zufallszeichenfolge. Wenn nicht gesetzt, wird ein Default genutzt
# (lokal ok, fuer Produktion bitte unbedingt einen eigenen Wert setzen).
# Generieren z.B. mit:  openssl rand -hex 32
AUTH_SECRET=
